<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- ================================ -->
    <!-- REQUIRED: App Sandbox for App Store -->
    <!-- ================================ -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- App + Team Identifier -->
    <key>com.apple.application-identifier</key>
    <string>YOUR_TEAM_ID.im.hades.messaging</string>

    <key>com.apple.developer.team-identifier</key>
    <string>YOUR_TEAM_ID</string>

    <!-- ================================ -->
    <!-- Network: Tor + Relay connections -->
    <!-- ================================ -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- ================================ -->
    <!-- Hardware: Calls -->
    <!-- ================================ -->
    <!-- Camera (Video Calls) -->
    <key>com.apple.security.device.camera</key>
    <true/>

    <!-- Microphone (Voice/Video Calls + Voice Messages) -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- ================================ -->
    <!-- Files: Media Attachments -->
    <!-- ================================ -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>

    <!-- ================================ -->
    <!-- Push Notifications -->
    <!-- ================================ -->
    <key>com.apple.developer.push-notifications</key>
    <true/>
    <key>aps-environment</key>
    <string>production</string>

    <!-- ================================ -->
    <!-- Keychain: Seed Phrase + Keys -->
    <!-- ================================ -->
    <key>com.apple.security.keychain</key>
    <true/>
    <key>keychain-access-groups</key>
    <array>
        <string>YOUR_TEAM_ID.im.hades.messaging</string>
    </array>
</dict>
</plist>
